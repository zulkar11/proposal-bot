# ── LLM Configuration ──────────────────────────────────────
# Required. Your API key for the LLM provider.
OPENAI_API_KEY=your-z-ai-api-key-here

# Model name to use.
#   z.ai:      glm-5.1
#   OpenAI:    gpt-4o
#   Gemini:    gemini/gemini-1.5-pro
#   Ollama:    ollama_chat/llama3
#   Anthropic: anthropic/claude-sonnet-4-20250514
LLM_MODEL=glm-5.1

# Custom API base URL for OpenAI-compatible providers.
# Leave empty for default provider (OpenAI).
#   z.ai:      https://api.z.ai/api/paas/v4/
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:    http://localhost:11434
LLM_API_BASE=https://api.z.ai/api/paas/v4/

# ── Pipeline Configuration ─────────────────────────────────
# Max times the Reviewer can send estimation back for revision (0 = no reflection)
MAX_REVISION_ROUNDS=1

# ── Server Configuration ───────────────────────────────────
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000
